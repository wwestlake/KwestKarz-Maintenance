# /opt/kwestkarz/env
# Copy this file to the server as /opt/kwestkarz/env and fill in real values.
# This file is loaded by systemd as EnvironmentFile — one KEY=value per line.
# Never commit the real file. Never commit this file with real values.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://localhost:5081

# PostgreSQL connection string
ConnectionStrings__KwestKarz=Host=localhost;Port=5432;Database=KwestKarz;Username=kwestkarz;Password=CHANGE_ME;Search Path=kwestkarzbusinessdata

# OpenAI
OpenAI__ApiKey=CHANGE_ME

# Firebase admin bootstrap — your phone number in E.164 format e.g. +12065551234
Auth__AdminPhoneNumber=CHANGE_ME

# File storage — absolute path on the server
Storage__RootPath=/opt/kwestkarz/storage

# Optional: enable DB-level request logging
SystemLog__Enabled=false
